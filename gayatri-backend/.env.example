APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# MUST be false in production — true leaks stack traces (security) and is
# noticeably slower on shared hosting.
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Production (frontend + API on different subdomains, e.g. gayatrient.com +
# api.gayatrient.com): MUST be the parent domain with a LEADING DOT, e.g.
# SESSION_DOMAIN=.gayatrient.com — otherwise the Sanctum SPA cookie set by
# the API subdomain never gets sent back on requests from the main domain,
# and login will silently appear to do nothing. Leave as null for local dev.
SESSION_DOMAIN=null

# Comma-separated. Sanctum only treats requests from these domains as
# "stateful" (cookie-based) — list the FRONTEND domain(s) here, not the API
# domain. Example prod value: gayatrient.com,www.gayatrient.com
SANCTUM_STATEFUL_DOMAINS=localhost:3010

# Comma-separated, full origin with protocol — used for CORS. Example prod
# value: https://gayatrient.com,https://www.gayatrient.com
FRONTEND_URLS=http://localhost:3010

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Used by App\Console\Commands\GenerateDailyBlog (the AI Insights blog cron).
GEMINI_API_KEY=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
